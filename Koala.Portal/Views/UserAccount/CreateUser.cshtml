@using Microsoft.AspNetCore.Mvc.ModelBinding
@model Koala.Portal.WebUI.Models.ViewModels.CreateUserViewModel
@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}


<div class="d-flex flex-column-fluid">

    <div class="container-fluid">

        <div class="row">
            <div class="col-lg-12">
                <form name="CreateUserForm" id="CreateUserForm" asp-action="CreateUser" asp-controller="UserAccount" method="post">
                    <div class="card card-custom card-stretch gutter-b">
                        <div class="card-header border-0 py-5">
                            <h3 class="card-title align-items-start flex-column">
                                <span class="card-label font-weight-bolder text-dark">Kullanıcı Yönetimi</span>
                                <span class="text-muted mt-3 font-weight-bold font-size-sm">Yeni Kullanıcı Ekle</span>
                            </h3>
                        </div>
                        <div class="card-body pt-0 pb-3">
                            <div class="tab-content">
                              
                                @*<div class="text-center">
                                <h1 class="display-4">Hoşgeşdiniz</h1>
                                <p>Koala Hakkında Daha Fazla Bilgiye Ulaşmak için  <a href="mailto:info@sistem-bilgisayar.com" target="_blank">Mail Atınız</a>.</p>
                                </div>*@


                                <div asp-validation-summary="ModelOnly"></div>

                                <div class="form-group row">
                                    <label asp-for="Name" class="col-1 col-form-label"></label>
                                    <div class="col-5">
                                        <input class="form-control form-control-sm" asp-for="Name" type="text" />
                                        <span asp-validation-for="Name" class="text-danger"></span>
                                    </div>
                                    <label asp-for="Lastname" class="col-1 col-form-label"></label>
                                    <div class="col-5">
                                        <input class="form-control form-control-sm" asp-for="Lastname" type="text" />
                                        <span asp-validation-for="Lastname" class="text-danger"></span>
                                    </div>
                                 
                                </div>

                                <div class="form-group row">
                                    <label asp-for="Title" class="col-1 col-form-label"></label>
                                    <div class="col-5">
                                        <input class="form-control form-control-sm" asp-for="Title" type="text" />
                                        <span asp-validation-for="Title" class="text-danger"></span>
                                    </div>
                                    <label asp-for="Email" class="col-1 col-form-label"></label>
                                    <div class="col-5">
                                        <input class="form-control form-control-sm" type="email" asp-for="Email" />
                                        <span asp-validation-for="Email" class="text-danger"></span>

                                    </div>
                                   
                                </div>

                                <div class="form-group row">
                                    <label asp-for="Password" class="col-1 col-form-label"></label>
                                    <div class="col-5">
                                        <input class="form-control form-control-sm" type="password" asp-for="Password" />
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                    <label asp-for="PhoneNumber" class="col-1 col-form-label"></label>
                                    <div class="col-5">
                                        <input class="form-control form-control-sm" type="text" asp-for="PhoneNumber" />
                                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer">
                            <button type="submit" class="btn btn-primary mr-2">Kullanıcı Ekle</button>
                            <button type="reset" class="btn btn-secondary">Vazgeç</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>




    </div>

</div>


@section Scripts
{
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
