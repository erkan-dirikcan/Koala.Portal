@using Koala.Portal.Core.Dtos
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<Koala.Portal.Core.ViewModels.PortalViewModels.VacationTypesViewModel>

@{
    ViewData["Title"] = "izin Tipleri";
    var infoMessage = TempData["InfoMessage"] == null ? "" : TempData["InfoMessage"].ToString();
    var errorMessage = TempData["ErrorMessage"] == null ? "" : TempData["ErrorMessage"].ToString();
    ViewData["ActivePage"] = "VacationTypes";
    ViewData["MenuToggle"] = "Settings";
}

<div class="d-flex flex-column-fluid">

    <div class="container-fluid">

        <div class="row">
            <div class="col-lg-12">

                <div class="card card-custom">
                    <div class="card-header flex-wrap border-0 pt-6 pb-0">
                        <div class="card-title">
                            <h3 class="card-label">
                                İzin Tipi Yönetimi
                                <span class="d-block text-muted pt-2 font-size-sm">İzin Tipi Listesi</span>
                            </h3>
                        </div>
                        <div class="card-toolbar">

                            <!--begin::Button-->
                            <a asp-action="Create" asp-controller="VacationTypes" class="btn btn-primary font-weight-bolder btn-sm">
                                <span class="svg-icon svg-icon-light-primary svg-icon-2x">
                                    <!--begin::Svg Icon | path:C:\wamp64\www\keenthemes\legacy\metronic\theme\html\demo1\dist/../src/media/svg/icons\Code\Plus.svg-->
                                    <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="24px" height="24px" viewBox="0 0 24 24" version="1.1">
                                        <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                                            <rect x="0" y="0" width="24" height="24" />
                                            <circle fill="#000000" opacity="0.3" cx="12" cy="12" r="10" />
                                            <path d="M11,11 L11,7 C11,6.44771525 11.4477153,6 12,6 C12.5522847,6 13,6.44771525 13,7 L13,11 L17,11 C17.5522847,11 18,11.4477153 18,12 C18,12.5522847 17.5522847,13 17,13 L13,13 L13,17 C13,17.5522847 12.5522847,18 12,18 C11.4477153,18 11,17.5522847 11,17 L11,13 L7,13 C6.44771525,13 6,12.5522847 6,12 C6,11.4477153 6.44771525,11 7,11 L11,11 Z" fill="#000000" />
                                        </g>
                                    </svg><!--end::Svg Icon-->
                                </span>İzin Tipi Ekle
                            </a>
                            <!--end::Button-->
                        </div>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(infoMessage))
                        {

                            <div class="alert alert-success" role="alert">
                                @infoMessage
                                <div class="alert-close">
                                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true"><i class="ki ki-close"></i></span>
                                    </button>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {

                            <div class="alert alert-danger" role="alert">
                                @errorMessage
                                <div class="alert-close">
                                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true"><i class="ki ki-close"></i></span>
                                    </button>
                                </div>
                            </div>
                        }
                        <table class="table table-bordered table-hover" id="vacation-table" style="margin-top: 13px !important">
                            <thead>
                                <tr>
                                    <th title="Name">Tip Adı</th>
                                    <th title="Description">Tip Açıklaması</th>
                                    <th title="Description">Durum</th>
                                    <th title="Action">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.Name</td>
                                        <td>@item.Description</td>
                                        <td>
                                            @if (item.Status == Koala.Portal.Core.Dtos.StatusEnum.Active)
                                            {
                                                <span class="label label-success label-inline mr-2">Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="label label-danger label-inline mr-2">Pasif</span>
                                            }
                                        </td>

                                        <td>
                                            <a asp-controller="VacationTypes" asp-action="Update" asp-route-id="@item.Id" class="btn btn-icon btn-warning btn-sm" data-toggle="tooltip" title="Güncelle" data-theme="dark"><i class="flaticon-edit"></i></a>
                                            @if (item.Status == Koala.Portal.Core.Dtos.StatusEnum.Active)
                                            {
                                                <a asp-controller="VacationTypes" asp-action="ChangeStatus" asp-route-LineId="@item.Id" asp-route-Status="@StatusEnum.Active" class="btn btn-icon btn-danger btn-sm" data-toggle="tooltip" title="Pasife Çek" data-theme="dark"> <i class="flaticon2-cancel"></i></a>
                                            }
                                            else
                                            {
                                                <a asp-controller="VacationTypes" asp-action="ChangeStatus" asp-route-LineId="@item.Id" asp-route-Status="@StatusEnum.Active" class="btn btn-icon btn-success btn-sm" data-toggle="tooltip" title="Aktif Et" data-theme="dark"><i class="flaticon2-check-mark"></i></a>
                                            }
                                        </td>

                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="~/js/custom/VacationListPage.js"></script>
    <script type="text/javascript">

    </script>
}