@model Koala.Portal.Core.ViewModels.PortalViewModels.HelpDeskProblemCreateViewModel
@{
    ViewData["Title"] = "CreateHelpDeskProblem";
    var categories = (List<SelectListItem>)ViewData["CategoryName"]!;
}
<div class="d-flex flex-column-fluid">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">
                <form name="CreateHelpDeskProblemForm" id="CreateForm" asp-action="CreateHelpDeskProblem" asp-controller="HelpDeskProblem" method="post">
                    <div class="card card-custom card-stretch gutter-b">
                        <div class="card-header border-0 py-5">
                            <h3 class="card-title align-items-start flex-column">
                                <span class="card-label font-weight-bolder text-dark">Yardım Masası</span>
                                <span class="text-muted mt-3 font-weight-bold font-size-sm">Yardım Masası Problemi Ekle</span>
                            </h3>
                        </div>
                        <div class="card-body pt-0 pb-3">
                            <div class="tab-content">
                                <div asp-validation-summary="ModelOnly"></div>
                                <div class="form-group row">
                                    <label asp-for="Title" class="col-md-1 col-form-label">Başlık</label>
                                    <div class="col-md-5">
                                        <input class="form-control form-control-sm" asp-for="Title" type="text" />
                                        <span asp-validation-for="Title" class="text-danger"></span>
                                    </div>
                                    <label class="col-md-1 col-form-label">Kategori</label>
                                   @*  <div class="col-md-5">
                                        <select class="form-control form-control-sm" asp-for="CategoryId" asp-items="categories"> </select>
                                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                                    </div> *@
                                    <label asp-for="Content" class="col-md-1 col-form-label">İçerik</label>
                                    <div class="col-md-11">
                                        @if (Model != null)
                                        {
                                            <textarea class="form-control" name="Content" id="Content" rows="15">@Model.Content</textarea>
                                        }
                                        else
                                        {
                                            <textarea class="form-control" name="Content" id="Content" rows="15"></textarea>

                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer">
                            <button type="submit" class="btn btn-primary mr-2">Problem Ekle</button>
                            <a href="~/HelpDeskProblem" class="btn btn-secondary">Vazgeç</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/plugins/custom/ckeditor_/ckeditor.js"></script>

    <script type="text/javascript">
        $('#CategoryId').select2({
            placeholder: ""
        });
        var editor = CKEDITOR.replace('Content',
            {
                extraPlugins: 'codesnippet',
                codeSnippet_theme: 'atelier-forest.light'
            });

    </script>
}