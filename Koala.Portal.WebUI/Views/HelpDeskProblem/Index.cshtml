@using Koala.Portal.Core.Dtos
@model List<Koala.Portal.Core.ViewModels.PortalViewModels.HelpDeskProblemInfoViewModels>
@{
    var errorMessage = TempData["ErrorMessage"] == null ? "" : TempData["ErrorMessage"].ToString();
    var infoMessage = TempData["InfoMessage"] == null ? "" : TempData["InfoMessage"].ToString();
    ViewData["Title"] = "Yardım Masası Problem Listesi";
    ViewData["ActivePage"] = "HelpDeskProblem";
    ViewData["MenuToggle"] = "HelpDesk";
}
<div class="d-flex flex-column-fluid">

    <div class="container-fluid">

        <div class="row">
            <div class="col-lg-12">

                <div class="card card-custom">
                    <div class="card-header flex-wrap border-0 pt-6 pb-0">
                        <div class="card-title">
                            <h3 class="card-label">
                                Yardım Masası Problemleri
                                <span class="d-block text-muted pt-2 font-size-sm">Yardım Masası Problem Listesi</span>
                            </h3>
                        </div>
                        <div class="card-toolbar">

                            <!--begin::Button-->
                            <a asp-action="CreateHelpDeskProblem" asp-controller="HelpDeskProblem" class="btn btn-primary font-weight-bolder">

                                <span class="svg-icon svg-icon-md">
                                    <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="24px" height="24px" viewBox="0 0 24 24" version="1.1">
                                        <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                                            <rect x="0" y="0" width="24" height="24" />
                                            <circle fill="#000000" cx="9" cy="15" r="6" />
                                            <path d="M8.8012943,7.00241953 C9.83837775,5.20768121 11.7781543,4 14,4 C17.3137085,4 20,6.6862915 20,10 C20,12.2218457 18.7923188,14.1616223 16.9975805,15.1987057 C16.9991904,15.1326658 17,15.0664274 17,15 C17,10.581722 13.418278,7 9,7 C8.93357256,7 8.86733422,7.00080962 8.8012943,7.00241953 Z" fill="#000000" opacity="0.3" />
                                        </g>
                                    </svg>
                                    <!--end::Svg Icon-->
                                </span>Yardım Masası Problem Ekle
                            </a>
                            <!--end::Button-->
                        </div>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(infoMessage))
                        {

                            <div class="alert alert-success" role="alert">
                                @infoMessage
                                <div class="alert-close">
                                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true"><i class="ki ki-close"></i></span>
                                    </button>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {

                            <div class="alert alert-danger" role="alert">
                                @errorMessage
                                <div class="alert-close">
                                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true"><i class="ki ki-close"></i></span>
                                    </button>
                                </div>
                            </div>
                        }
                        <table class="table table-bordered table-hover" id="ProblemTable" style="margin-top: 13px !important">
                            <thead>
                                <tr>
                                    <th title="Name">Başlık</th>
                                    <th title="Description">Kategori</th>
                                    <th title="Status">Durum</th>
                                    <th title="Action">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.Title</td>
                                        @{
                                            var categoriNames = item.Categories.Select(c => c.Name).ToList();
                                            var categoryNamesStr = string.Join(", ", categoriNames);
                                        }
                                        
                                        <td>@categoryNamesStr</td>
                                        <td>
                                            @if (item.Status == StatusEnum.Active)
                                            {
                                                <span class="label label-success label-inline mr-2">Aktif</span>
                                            }
                                            else if (item.Status == StatusEnum.Pasive)
                                            {
                                                <span class="label label-danger label-inline mr-2">Pasif</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-controller="HelpDeskProblem" asp-action="UpdateHelpDeskProblem" asp-route-id="@item.Id" class="btn btn-icon btn-warning btn-sm" data-toggle="tooltip" title="Güncelle" data-theme="dark"><i class="flaticon-edit"></i></a>
                                            <a asp-controller="HelpDeskProblem" asp-action="ChangeProblemStatus" asp-route-id="@item.Id" asp-route-status="@StatusEnum.Deleted" class="btn btn-icon btn-danger btn-sm" data-toggle="tooltip" title="Sil" data-theme="dark"> <i class="flaticon2-trash"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="~/js/custom/helpdeskproblemlist.js"></script>
}