@model Koala.Portal.Core.ViewModels.PortalViewModels.HelpDeskSolitionUpdateViewModel
@{
    ViewData["Title"] = "UpdateHelpDeskSolution";
    var problems = (List<SelectListItem>)ViewData["ProblemName"]!;
}
<div class="d-flex flex-column-fluid">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">
                <form name="CreateUserForm" id="CreateForm" asp-action="UpdateHelpDeskSolution" asp-controller="HelpDeskSolution" method="post">
                    <div class="card card-custom card-stretch gutter-b">
                        <div class="card-header border-0 py-5">
                            <h3 class="card-title align-items-start flex-column">
                                <span class="card-label font-weight-bolder text-dark">Yardım Masası</span>
                                <span class="text-muted mt-3 font-weight-bold font-size-sm">Yardım Masası Çözümünü Güncelle</span>
                            </h3>
                        </div>
                        <div class="card-body pt-0 pb-3">
                            <div class="tab-content">
                                <div asp-validation-summary="ModelOnly"></div>
                                <div class="form-group row">
                                    <label asp-for="Title" class="col-md-1 col-form-label">Başlık</label>
                                    <div class="col-md-5">
                                        <input class="form-control form-control-sm" asp-for="Title" type="text" />
                                        <span asp-validation-for="Title" class="text-danger"></span>
                                    </div>
                                    <label class="col-md-1 col-form-label">Problem</label>
                                    <div class="col-md-5">
                                        <select class="form-control form-control-sm" asp-for="HelpDeskProblemId" asp-items="problems"> </select>
                                        <span asp-validation-for="HelpDeskProblemId" class="text-danger"></span>
                                    </div>
                                    
                                    <label asp-for="Title" class="col-md-1 col-form-label">Açıklama</label>
                                    <div class="col-md-5">
                                        <input class="form-control form-control-sm" asp-for="Description" type="text" />
                                        <span asp-validation-for="Description" class="text-danger"></span>
                                    </div>

                                    <label class="col-1 col-form-label" asp-for="CustomerCanSee">Müşteri Görebilir Mi ?</label>
                                    <div class="col-1">
                                        <span class="switch switch-outline switch-sm switch-icon switch-success">
                                            <label>
                                                <input type="checkbox" asp-for="@Model.CustomerCanSee" />
                                                <span></span>
                                            </label>
                                        </span>
                                    </div>
                                    <label class="col-md-4 col-form-label"></label>

                                    <label asp-for="Content" class="col-md-1 col-form-label">İçerik</label>
                                    <div class="col-md-5">
                                        @if (Model != null)
                                        {
                                            <textarea class="form-control" name="Content" id="Content" rows="15">@Model.Content</textarea>
                                        }
                                        else
                                        {
                                            <textarea class="form-control" name="Content" id="Content" rows="15"></textarea>

                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer">
                            <button type="submit" class="btn btn-primary mr-2">Çözüm Güncelle</button>
                            <a href="~/HelpDeskSolution" class="btn btn-secondary">Vazgeç</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts
{
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/plugins/custom/ckeditor_/ckeditor.js"></script>

    <script type="text/javascript">
        $('#HelpDeskProblemId').select2({
            placeholder: ""
        });
        var editor = CKEDITOR.replace('Content',
            {
                extraPlugins: 'codesnippet',
                codeSnippet_theme: 'atelier-forest.light'
            });

    </script>
}

