@using Microsoft.AspNetCore.Mvc.TagHelpers
@model Koala.Portal.Core.ViewModels.PortalViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Yeni Şifre Tanımla";

}

<div class="d-flex flex-column-fluid">

    <div class="container-fluid">

        <div class="row">
            <div class="col-lg-12">
                <form name="CreateUserForm" id="CreateUserForm" asp-action="ResetPassword" asp-controller="UserAccount" method="post">
                    <div class="card card-custom card-stretch gutter-b">
                        <div class="card-header border-0 py-5">
                            <h3 class="card-title align-items-start flex-column">
                                <span class="card-label font-weight-bolder text-dark">Kullanıcı Yönetimi</span>
                                <span class="text-muted mt-3 font-weight-bold font-size-sm">Yeni Kullanıcı Ekle</span>
                            </h3>
                        </div>
                        <div class="card-body pt-0 pb-3">
                            <div class="tab-content">

                               
                                <div asp-validation-summary="ModelOnly"></div>

                                <div class="form-group row">
                                    <label asp-for="Password" class="col-md-1 col-form-label"></label>
                                    <div class="col-md-5">
                                        <input class="form-control form-control-sm" asp-for="Password" type="password" />
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                    <label asp-for="ConfirmPassword" class="col-md-1 col-form-label"></label>
                                    <div class="col-md-5">
                                        <input class="form-control form-control-sm" asp-for="ConfirmPassword" type="password" />
                                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                    </div>

                                </div>

                            </div>
                        </div>
                        <div class="card-footer">
                            <button type="submit" class="btn btn-primary mr-2">Şifre Yenile</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

</div>


