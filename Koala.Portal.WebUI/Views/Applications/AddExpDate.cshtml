@model Koala.Portal.Core.ViewModels.PortalViewModels.ApplicationsAddExpDateViewModel
@{
    ViewData["Title"] = "Uygulama Son Kullanım Tarihi Güncelle";
    ViewData["ActivePage"] = "ApplicationsList";
    ViewData["MenuToggle"] = "Applications";
}
}
<div class="d-flex flex-column-fluid">

    <div class="container-fluid">

        <div class="row">

            <div class="col-lg-12">
                <form name="CreateUserForm" id="CreateFixtureForm" asp-action="AddExpDate" asp-controller="Applications" method="post">
                    <div class="card card-custom card-stretch gutter-b">
                        <div class="card-header border-0 py-5">
                            <h3 class="card-title align-items-start flex-column">
                                <span class="card-label font-weight-bolder text-dark">Uygulama Yönetimi</span>
                                <span class="text-muted mt-3 font-weight-bold font-size-sm">Yeni Uygulama Ekle</span>
                            </h3>
                        </div>
                        <div class="card-body pt-0 pb-3">
                            <div class="tab-content">
                                <div asp-validation-summary="ModelOnly"></div>
                                @Html.HiddenFor(x => x.Id)
                                @Html.HiddenFor(x => x.Name)
                                @Html.HiddenFor(x => x.Description)
                                <div class="form-group row">
                                    <div class="col-6 row">
                                        <div class="col-4 text-right">
                                            <span class="text-danger font-size-sm col-form-label font-weight-bolder">Uygulama Adı : </span>
                                        </div>
                                        <div class="col-8 text-left">
                                            <span class="text-muted font-size-sm">@Model.Name</span>
                                        </div>
                                    </div>

                                    <div class="col-6 row">
                                        <div class="col-4 text-right">
                                            <span class="text-danger font-size-sm col-form-label font-weight-bolder">Uygulama Açıklaması : </span>
                                        </div>
                                        <div class="col-8 text-left">
                                            <span class="text-muted font-size-sm">@Model.Description</span>
                                        </div>
                                    </div>
                                </div>
                               
                                <div class="form-group row">
                                    <label class="col-form-label text-right col-lg-2 col-sm-12">Geçerlilik Tarihi</label>
                                    <div class=" col-lg-10 col-sm-12">
                                        <div class="input-group date" id="ExpDate_time" data-target-input="nearest">
                                            <input type="text" class="form-control datetimepicker-input" placeholder="Select date &amp; time" asp-for="ExpDate" value="@DateTime.Now.ToString("dd-MM-yyyy HH:mm")" data-target="#ExpDate_time" />
                                            <div class="input-group-append" data-target="#ExpDate_time" data-toggle="datetimepicker">
                                                <span class="input-group-text">
                                                    <i class="ki ki-calendar"></i>
                                                </span>
                                            </div>
                                        </div>
                                        <span asp-validation-for="ExpDate" class="text-danger"></span>
                                    </div>
                                </div>

                            </div>
                        </div>
                        <div class="card-footer">
                            <button type="submit" class="btn btn-warning mr-2">Uygulama Son Kullanım Tarihi Güncelle</button>
                            <a href="~/Applications" class="btn btn-secondary">Vazgeç</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>




    </div>

</div>

@section Scripts
{
    <script src="~/js/custom/createapplicationpage.js"></script>
}
