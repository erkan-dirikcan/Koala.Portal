@using Koala.Portal.Core.Dtos
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService;
@model IEnumerable<Koala.Portal.Core.ViewModels.PortalViewModels.ApplicationsListViewModel>
@{
    ViewData["Title"] = "Uygulama Listesi";
    var infoMessage = TempData["InfoMessage"] == null ? "" : TempData["InfoMessage"]!.ToString();
    var errorMessage = TempData["ErrorMessage"] == null ? "" : TempData["ErrorMessage"]!.ToString();
    ViewData["ActivePage"] = "ApplicationsList";
    ViewData["MenuToggle"] = "Applications";
}

<div class="d-flex flex-column-fluid">

    <div class="container-fluid">

        <div class="row">
            <div class="col-lg-12">

                <div class="card card-custom">
                    <div class="card-header flex-wrap border-0 pt-6 pb-0">
                        <div class="card-title">
                            <h3 class="card-label">
                                Uygulama Yönetimi
                                <span class="d-block text-muted pt-2 font-size-sm">Uygulama Listesi</span>
                            </h3>
                        </div>
                        <div class="card-toolbar">

                            <!--begin::Button-->
                            @if (AuthorizationService.AuthorizeAsync(User, "AppLicationManagement.Create").Result.Succeeded)
                            {
                                <a asp-action="Create" asp-controller="Applications" class="btn btn-primary font-weight-bolder">
                                    <span class="svg-icon svg-icon-md">


                                        <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="24px" height="24px" viewBox="0 0 24 24" version="1.1">
                                            <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                                                <rect x="0" y="0" width="24" height="24" />
                                                <path d="M17.2718029,8.68536757 C16.8932864,8.28319382 16.9124644,7.65031935 17.3146382,7.27180288 C17.7168119,6.89328641 18.3496864,6.91246442 18.7282029,7.31463817 L22.7282029,11.5646382 C23.0906029,11.9496882 23.0906029,12.5503176 22.7282029,12.9353676 L18.7282029,17.1853676 C18.3496864,17.5875413 17.7168119,17.6067193 17.3146382,17.2282029 C16.9124644,16.8496864 16.8932864,16.2168119 17.2718029,15.8146382 L20.6267538,12.2500029 L17.2718029,8.68536757 Z M6.72819712,8.6853647 L3.37324625,12.25 L6.72819712,15.8146353 C7.10671359,16.2168091 7.08753558,16.8496835 6.68536183,17.2282 C6.28318808,17.6067165 5.65031361,17.5875384 5.27179713,17.1853647 L1.27179713,12.9353647 C0.909397125,12.5503147 0.909397125,11.9496853 1.27179713,11.5646353 L5.27179713,7.3146353 C5.65031361,6.91246155 6.28318808,6.89328354 6.68536183,7.27180001 C7.08753558,7.65031648 7.10671359,8.28319095 6.72819712,8.6853647 Z" fill="#000000" fill-rule="nonzero" />
                                                <rect fill="#000000" opacity="0.3" transform="translate(12.000000, 12.000000) rotate(-345.000000) translate(-12.000000, -12.000000) " x="11" y="4" width="2" height="16" rx="1" />
                                            </g>
                                        </svg>

                                    </span>Uygulama Ekle
                                </a>
                            }

                        </div>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(infoMessage))
                        {

                            <div class="alert alert-success" role="alert">
                                @infoMessage
                                <div class="alert-close">
                                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true"><i class="ki ki-close"></i></span>
                                    </button>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {

                            <div class="alert alert-danger" role="alert">
                                @errorMessage
                                <div class="alert-close">
                                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true"><i class="ki ki-close"></i></span>
                                    </button>
                                </div>
                            </div>
                        }
                        <table class="table table-bordered table-hover" id="applicationTable" style="margin-top: 13px !important">
                            <thead>
                                <tr>
                                    <th title="Name">Uygulama Adı</th>
                                    <th title="Description">Uygulama Açıklaması</th>
                                    <th title="IsVehicle">Son Kullanım Tarihi</th>
                                    <th title="IsVehicle">En Fazla Kullanıcı Sayısı</th>
                                    <th title="Status">Durum</th>
                                    @if (AuthorizationService.AuthorizeAsync(User, "AppLicationManagement.Create").Result.Succeeded)
                                    {
                                        <th title="Action">İşlemler</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var statusClass = "";
                                    var status = "";
                                    var maxUser = item.MaxUserCount > 0 ?
                                    $"<span class=\"label label-light-info label-pill label-inline mr-2\">{item.MaxUserCount} Kullanıcı</span>" :
                                    "<span class=\"label label-light-success label-pill label-inline mr-2\">Sınırsız Kullanıcı</span>";

                                    switch (item.Status)
                                    {
                                        case StatusEnum.Active:
                                            statusClass = "label-success";
                                            status = "Aktif";
                                            break;
                                        case StatusEnum.Pasive:
                                            statusClass = "label-danger";
                                            status = "Pasif";
                                            break;
                                        case StatusEnum.Deleted:
                                            statusClass = "label-danger";
                                            status = "Silinmiş";
                                            break;
                                        case StatusEnum.Expiration:
                                            statusClass = "label-warning";
                                            status = "Süresi Dolmuş";
                                            break;
                                    }
                                    <tr>
                                        <td>@item.Name</td>
                                        <td>@item.Description</td>
                                        <td>
                                            @item.ExpDate.ToString("dd-MM-yyyy")
                                        </td>
                                        <td>
                                            @Html.Raw(maxUser)
                                        </td>
                                        <td>
                                            <span class="label @statusClass label-pill label-inline mr-2">@status</span>
                                        </td>

                                        @if (AuthorizationService.AuthorizeAsync(User, "AppLicationManagement.Create").Result.Succeeded)
                                        {
                                            <td>
                                                <a asp-controller="Applications" asp-action="Update" asp-route-id="@item.Id" class="btn btn-icon btn-warning btn-sm m-5" data-toggle="tooltip" title="Güncelle" data-theme="dark"><i class="flaticon-edit"></i></a>
                                                @if (item.Status == StatusEnum.Active)
                                                {
                                                    <a asp-controller="Applications" asp-action="ChangeStatus" asp-route-id="@item.Id" asp-route-status="@StatusEnum.Pasive" class="btn btn-icon btn-danger btn-sm m-5" data-toggle="tooltip" title="Pasife Çek" data-theme="dark"><i class="fas fa-lock"></i></a>
                                                }
                                                else
                                                {
                                                    <a asp-controller="Applications" asp-action="ChangeStatus" asp-route-id="@item.Id" asp-route-status="@StatusEnum.Active" class="btn btn-icon btn-success btn-sm m-5" data-toggle="tooltip" title="Aktif Et" data-theme="dark"><i class="fas fa-lock-open"></i></a>
                                                }
                                                @if (item.Status == StatusEnum.Expiration && !item.IsPackageApplication)
                                                {
                                                <a asp-controller="Applications" asp-action="AddExpDate" asp-route-id="@item.Id" class="btn btn-icon btn-primary btn-sm m-5" data-toggle="tooltip" title="Lisan Kullanıcım Uzat" data-theme="dark"><i class="far fa-calendar-plus"></i></a>
                                                }
                                                @if (item.IsPackageApplication)
                                                {
                                                    <button class="btn btn-icon btn-success btn-sm add-firm-bt m-5" data-id="@item.Id" data-toggle="tooltip" title="Uygulama Firması Ekle" data-theme="dark"><i class="fas fa-user-plus"></i></button>
                                                    <a asp-controller="Applications" asp-action="ApplicationFirms" asp-route-id="@item.Id" class="btn btn-icon btn-info btn-sm m-5" data-id="@item.Id" data-toggle="tooltip" title="Uygulama Firmaları" data-theme="dark"><i class="far fa-building"></i></a>
                                                }
                                                @if (item.IsMultiModuleApplication)
                                                {
                                                    <button class="btn btn-icon btn-light-primary btn-sm add-firm-bt m-5" data-id="@item.Id" data-toggle="tooltip" title="Uygulama Modül Ekle" data-theme="dark"><i class="fas fa-user-plus"></i></button>
                                                    <a asp-controller="Applications" asp-action="ApplicationFirms" asp-route-id="@item.Id" class="btn btn-icon btn-light-info btn-sm m-5" data-id="@item.Id" data-toggle="tooltip" title="Uygulama Modülleri" data-theme="dark"><i class="far fa-building"></i></a>
                                                }
                                            </td>
                                        }

                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="add-application-firm-modal" tabindex="-1" role="dialog" aria-labelledby="support-send-to-user-modal" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="add-application-firm-modal-title">Uygulama Firması Ekle</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <i aria-hidden="true" class="ki ki-close"></i>
                </button>
            </div>
            <div class="modal-body">
                <form class="">
                    <div class="form-group row">
                        <label class="col-form-label text-right col-lg-2 col-sm-12">Firma</label>
                        <div class="col-lg-10 col-md-10 col-sm-12">
                            <firm-select selected-id="" id="selected-application-firm-sl" name="selected-application-firm-sl"></firm-select>
                        </div>
                    </div>
                </form>
            </div>


            <div class="modal-footer">
                <button type="button" class="btn btn-light-primary font-weight-bold" data-dismiss="modal">İptal</button>
                <button type="button" id="add-firm-to-application-bt" class="btn btn-success font-weight-bold">Uygulamaya Firma Ekle</button>
            </div>
        </div>
    </div>
</div>



@section Scripts
{
    <script src="~/js/custom/applicationlist.js"></script>
}
