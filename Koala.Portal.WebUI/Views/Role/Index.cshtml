@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Mvc.TagHelpers
@inject IAuthorizationService AuthorizationService;
@model IEnumerable<Koala.Portal.Core.ViewModels.PortalViewModels.RoleListViewModel>
@{
    ViewData["Title"] = "Index";
    ViewData["ActivePage"] = "Roles";
    ViewData["MenuToggle"] = "UserAccount";
}

<div class="d-flex flex-column-fluid">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">

                <div class="card card-custom">
                    <div class="card-header flex-wrap border-0 pt-6 pb-0">
                        <div class="card-title">
                            <h3 class="card-label">
                                Roller
                                <span class="d-block text-muted pt-2 font-size-sm">Kullanıcı Rolleri</span>
                            </h3>
                        </div>
                        <div class="card-toolbar">

                            @if (AuthorizationService.AuthorizeAsync(User, "ManageUser.CreateRole").Result.Succeeded)
                            {
                                <a asp-action="CreateRole" asp-controller="Role" class="btn btn-primary font-weight-bolder">
                                    <span class="svg-icon svg-icon-md">
                                        <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="24px" height="24px" viewBox="0 0 24 24" version="1.1">
                                            <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                                                <rect x="0" y="0" width="24" height="24" />
                                                <circle fill="#000000" cx="9" cy="15" r="6" />
                                                <path d="M8.8012943,7.00241953 C9.83837775,5.20768121 11.7781543,4 14,4 C17.3137085,4 20,6.6862915 20,10 C20,12.2218457 18.7923188,14.1616223 16.9975805,15.1987057 C16.9991904,15.1326658 17,15.0664274 17,15 C17,10.581722 13.418278,7 9,7 C8.93357256,7 8.86733422,7.00080962 8.8012943,7.00241953 Z" fill="#000000" opacity="0.3" />
                                            </g>
                                        </svg>
                                        <!--end::Svg Icon-->
                                    </span>Rol Ekle
                                </a>
                            }
                        </div>
                    </div>
                    <div class="card-body">

                        <table class="table table-bordered table-hover" id="FirmTable" style="margin-top: 13px !important">
                            <thead>
                                <tr>
                                    <th title="Name">Rol Adı</th>
                                    <th title="Description">Rol Açıklaması</th>

                                    <th title="Action">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td title="Name">@item.Name</td>
                                        <td title="Description">@item.Description</td>
                                        <td>
                                            @if (AuthorizationService.AuthorizeAsync(User, "ManageUser.UpdateRole").Result.Succeeded)
                                            {
                                                <a asp-controller="Role" asp-action="UpdateRole" asp-route-id="@item.Id" class="btn btn-icon btn-success btn-sm" data-toggle="tooltip" title="Güncelle" data-theme="dark"><i class="flaticon-edit"></i></a>
                                            }
                                            @if (AuthorizationService.AuthorizeAsync(User, "ManageUser.Claims").Result.Succeeded)
                                            {
                                                <a asp-controller="Role" asp-action="AddClaimToRole" asp-route-id="@item.Id" class="btn btn-icon btn-warning btn-sm" data-toggle="tooltip" title="Yetki Güncelle"><i class="flaticon-list"></i></a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

