@model Koala.Portal.Core.ViewModels.PortalViewModels.CreateClaimViewModels
@{
    var ModuleInfo = ViewData["ModuleInfo"]!.ToString()!;
    ViewData["Title"] = "Yetki Ekle";
    ViewData["ActivePage"] = "Module";
    ViewData["MenuToggle"] = "Settings";
}

<div class="d-flex flex-column-fluid">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">
                <div class="card card-custom card-stretch gutter-b">
                    <div class="card-header border-0 py-5">
                        <h3 class="card-title align-items-start flex-column">
                            <span class="card-label font-weight-bolder text-dark">@ModuleInfo  Modül Yetki Yönetimi</span>
                            <span class="text-muted mt-3 font-weight-bold font-size-sm">Modüle Yetki Ekle</span>
                        </h3>
                    </div>
                    <form name="AddClaimForm" id="CreateForm" asp-action="AddClaim" asp-controller="Module" method="post">
                        <div class="card-body pt-0 pb-3">
                            @Html.HiddenFor(x => x.ModuleId)
                            <div class="form-group row">
                                <label asp-for="Name" class="col-md-2 col-form-label"></label>
                                <div class="col-md-4">
                                    <input class="form-control form-control-sm" asp-for="Name" type="text" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                                <label  class="col-md-2 col-form-label">Görünen Ad</label>
                                <div class="col-md-4">
                                    <input class="form-control form-control-sm" asp-for="DisplayName" type="text" />
                                    <span asp-validation-for="DisplayName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="col-md-2 col-form-label">Açıklama</label>
                                <textarea class="form-control" asp-for="Description" rows="3"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="card-footer">
                            <button type="submit" class="btn btn-primary mr-2">Yetki Ekle</button>
                            <a href="~/Module" class="btn btn-secondary">Vazgeç</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts
{
    <script type="text/javascript">

    </script>
}

