@using Microsoft.AspNetCore.Mvc.TagHelpers
@using Koala.Portal.Core.Dtos
@model List<Koala.Portal.Core.ViewModels.PortalViewModels.ProjectListViewModel>
@{
    ViewData["Title"] = "Proje Listesi";
    var infoMessage = TempData["InfoMessage"] == null ? "" : TempData["InfoMessage"].ToString();
    var errorMessage = TempData["ErrorMessage"] == null ? "" : TempData["ErrorMessage"].ToString();
    ViewData["ActivePage"] = "Projects";

    // Get filter values from TempData or use defaults
    var statusFilter = TempData["StatusFilter"]?.ToString() ?? "";
    var managerFilter = TempData["ManagerFilter"]?.ToString() ?? "";
    var firmFilter = TempData["FirmFilter"]?.ToString() ?? "";
    var startDate = TempData["StartDate"]?.ToString() ?? "";
    var endDate = TempData["EndDate"]?.ToString() ?? "";
    var searchTerm = TempData["SearchTerm"]?.ToString() ?? "";

    var users = (List<SelectListItem>)TempData["Users"]!;
    var firms = (List<SelectListItem>)TempData["Firms"]!;
}

<div class="d-flex flex-column-fluid">

    <div class="container-fluid">

        <div class="row">
            <div class="col-lg-12">

                <div class="card card-custom">
                    <div class="card-header flex-wrap border-0 pt-6 pb-0">
                        <div class="card-title">
                            <h3 class="card-label">
                                Proje Yönetimi
                                <span class="d-block text-muted pt-2 font-size-sm">Proje Listesi</span>
                            </h3>
                        </div>
                        <div class="card-toolbar">

                            <!--begin::Button-->
                            <a asp-action="CreateProject" asp-controller="Project" class="btn btn-primary font-weight-bolder">
                                <span class="svg-icon svg-icon-md">
                                    <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="24px" height="24px" viewBox="0 0 24 24" version="1.1">
                                        <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                                            <rect x="0" y="0" width="24" height="24" />
                                            <circle fill="#000000" cx="9" cy="15" r="6" />
                                            <path d="M8.8012943,7.00241953 C9.83837775,5.20768121 11.7781543,4 14,4 C17.3137085,4 20,6.6862915 20,10 C20,12.2218457 18.7923188,14.1616223 16.9975805,15.1987057 C16.9991904,15.1326658 17,15.0664274 17,15 C17,10.581722 13.418278,7 9,7 C8.93357256,7 8.86733422,7.00080962 8.8012943,7.00241953 Z" fill="#000000" opacity="0.3" />
                                        </g>
                                    </svg>
                                    <!--end::Svg Icon-->
                                </span>Proje Ekle
                            </a>
                            <!--end::Button-->
                        </div>
                    </div>
                    <div class="card-body">
                        <!-- Filter Panel -->
                        <div class="accordion accordion-solid accordion-toggle-arrow" id="filterAccordion">
                            <div class="card">
                                <div class="card-header">
                                    <div class="card-title collapsed" data-toggle="collapse" data-target="#filterContent">
                                        <i class="flaticon2-filter"></i>
                                        Filtreler
                                    </div>
                                </div>
                                <div id="filterContent" class="collapse show" data-parent="#filterAccordion">
                                    <div class="card-body">
                                        <form asp-action="Index" asp-controller="Project" method="get" id="filterForm">
                                            <div class="row">
                                                <div class="col-md-3 mb-2">
                                                    <label class="form-label">Durum</label>
                                                    <select name="statusFilter" class="form-control">
                                                        <option value="">Tümü</option>
                                                        @{
                                                            var statusOptions = new Dictionary<string, string>
                                                            {
                                                                { "Creating", "Oluşturuluyor" },
                                                                { "Created", "Oluşturuldu" },
                                                                { "Started", "Başladı" },
                                                                { "Testing", "Test Aşamasında" },
                                                                { "Finished", "Tamamlandı" },
                                                                { "Canceled", "İptal Edildi" },
                                                                { "Failed", "Başarısız" }
                                                            };
                                                            foreach (var opt in statusOptions)
                                                            {
                                                                var isSelected = statusFilter == opt.Key ? " selected" : "";
                                                                @:<option value="@opt.Key"@isSelected>@opt.Value</option>
                                                            }
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-md-3 mb-2">
                                                    <label class="form-label">Proje Yöneticisi</label>
                                                    <select name="managerFilter" class="form-control">
                                                        <option value="">Tümü</option>
                                                        @foreach (var user in users)
                                                        {
                                                            var isUserSelected = managerFilter == user.Value ? " selected" : "";
                                                            @:<option value="@user.Value"@isUserSelected>@user.Text</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-md-3 mb-2">
                                                    <label class="form-label">Firma</label>
                                                    <select name="firmFilter" class="form-control">
                                                        <option value="">Tümü</option>
                                                        @foreach (var firm in firms)
                                                        {
                                                            var isFirmSelected = firmFilter == firm.Value ? " selected" : "";
                                                            @:<option value="@firm.Value"@isFirmSelected>@firm.Text</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-md-3 mb-2">
                                                    <label class="form-label">Arama</label>
                                                    <input type="text" name="searchTerm" class="form-control" placeholder="Proje Adı veya Kodu" value="@searchTerm" />
                                                </div>
                                            </div>
                                            <div class="row">
                                                <div class="col-md-3 mb-2">
                                                    <label class="form-label">Başlangıç Tarihi</label>
                                                    <input type="date" name="startDate" class="form-control" value="@startDate" />
                                                </div>
                                                <div class="col-md-3 mb-2">
                                                    <label class="form-label">Bitiş Tarihi</label>
                                                    <input type="date" name="endDate" class="form-control" value="@endDate" />
                                                </div>
                                                <div class="col-md-6 mb-2 d-flex align-items-end">
                                                    <button type="submit" class="btn btn-primary mr-2">
                                                        <i class="flaticon2-search"></i> Filtrele
                                                    </button>
                                                    <a href="/Project" class="btn btn-secondary">
                                                        <i class="flaticon2-refresh"></i> Sıfırla
                                                    </a>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- End Filter Panel -->

                        @if (!string.IsNullOrEmpty(infoMessage))
                        {

                            <div class="alert alert-success" role="alert">
                                @infoMessage
                                <div class="alert-close">
                                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true"><i class="ki ki-close"></i></span>
                                    </button>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {

                            <div class="alert alert-danger" role="alert">
                                @errorMessage
                                <div class="alert-close">
                                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true"><i class="ki ki-close"></i></span>
                                    </button>
                                </div>
                            </div>
                        }
                        <table class="table table-bordered table-hover" id="ProjectTable" style="margin-top: 13px !important">
                            <thead>
                                <tr>
                                    <th title="ProjectCode">Proje Kodu</th>
                                    <th title="ProjectName">Proje Adı</th>
                                    <th title="ProjectManager">Proje Yöneticisi</th>
                                    <th title="Firm">Firma</th>
                                    <th title="StartDate">Başlangıç Tarihi</th>
                                    <th title="DueDate">Termin Tarihi</th>
                                    <th title="Action">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.ProjectCode</td>
                                        <td>@item.ProjectName</td>
                                        <td>@item.ProjectManager</td>
                                        <td>@item.Firm</td>
                                        <td>@item.StartDate</td>
                                        
                                        <td>@item.DueDate</td>
                                        <td>
                                            <a asp-controller="Project" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-icon btn-info btn-sm" data-toggle="tooltip" title="Detay" data-theme="dark"><i class="flaticon-eye"></i></a>
                                            <a asp-controller="Project" asp-action="UpdateProject" asp-route-id="@item.Id" class="btn btn-icon btn-warning btn-sm" data-toggle="tooltip" title="Düzenle" data-theme="dark"><i class="flaticon2-pen"></i></a>
                                            <button type="button" class="btn btn-icon btn-danger btn-sm btn-delete-project" data-toggle="tooltip" title="Sil" data-id="@item.Id" data-name="@item.ProjectName" data-theme="dark"><i class="flaticon2-trash"></i></button>
                                        </td>

                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="~/js/custom/ProjectListPage.js"></script>
}
