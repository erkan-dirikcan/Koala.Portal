@using Koala.Portal.Core.Dtos
@using Koala.Portal.WebUI.TagHelpers
@using Koala.Portal.Core.ViewModels.CrmViewModels
@using Koala.Portal.Core.ViewModels.PortalViewModels

@model (ProjectDetailViewModel project, InfoCrmFirmViewModel firm, List<CrmSupportListViewModel> supports, List<CrmUserFullNameInfoViewModel> crmUsers, List<CrmUserDepartmentsViewModel> userDepartments, List<SelectListItem> localUsers)
@{
    ViewData["Title"] = "Proje Detay";
    ViewData["ActivePage"] = "Project";
    TempData["IsProject"] = true;
    var phones = Model.firm.Phones.Select(x => $"({x.AreaCode}) {x.Number}").ToList();

    // Calculate progress
    var totalLines = Model.project.ProjectLines?.Count() ?? 0;
    var completedLines = Model.project.ProjectLines?.Count(l => l.StateStatus == ProjectLineStatusEnum.Completed) ?? 0;
    var progressPercent = totalLines > 0 ? (completedLines * 100 / totalLines) : 0;
}

<div class="d-flex flex-column-fluid">
    <!--begin::Container-->
    <div class="container-fluid">

        <!--begin::Project Header Card-->
        <div class="card card-custom gutter-b">
            <div class="card-body">
                <div class="d-flex">
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center justify-content-between flex-wrap">
                            <div class="mr-3">
                                <a href="#" class="d-flex align-items-center text-dark text-hover-primary font-size-h5 font-weight-bold mr-3">
                                    (@Model.project.Firm.Code) - @Model.project.Firm.Title
                                    <i class="flaticon2-correct text-success icon-md ml-2"></i>
                                </a>
                                <div class="d-flex flex-wrap my-2">
                                    @foreach (var phone in phones)
                                    {
                                        var pFormt = "0" + phone.Replace(" ", "").Replace("(", "").Replace(")", "");
                                        <a href="tel:@pFormt" class="text-muted text-hover-primary font-weight-bold mr-3">
                                            <span class="svg-icon svg-icon-md svg-icon-gray-500 mr-1">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24px" height="24px" viewBox="0 0 24 24" version="1.1">
                                                    <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                                                        <rect x="0" y="0" width="24" height="24" />
                                                        <path d="M8,2.5 C7.30964406,2.5 6.75,3.05964406 6.75,3.75 L6.75,20.25 C6.75,20.9403559 7.30964406,21.5 8,21.5 L16,21.5 C16.6903559,21.5 17.25,20.9403559 17.25,20.25 L17.25,3.75 C17.25,3.05964406 16.6903559,2.5 16,2.5 L8,2.5 Z" fill="#000000" opacity="0.3" />
                                                    </g>
                                                </svg>
                                            </span>
                                            @phone
                                        </a>
                                    }
                                </div>
                            </div>
                            <div class="my-lg-0 my-1">
                                <a href="/Project" class="btn btn-sm btn-light-primary font-weight-bolder mr-2">Listeye Dön</a>
                                <a href="#" id="open-add-project-file-modal" class="btn btn-sm btn-light-success font-weight-bolder text-uppercase">Dosya Ekle</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="separator separator-solid my-7"></div>

                <!-- Statistics -->
                <div class="d-flex align-items-center flex-wrap">
                    <div class="d-flex align-items-center flex-lg-fill mr-5 my-1">
                        <span class="mr-4"><i class="flaticon-app icon-2x text-muted font-weight-bold"></i></span>
                        <div class="d-flex flex-column text-dark-75">
                            <span class="font-weight-bolder font-size-sm">Toplam Faz</span>
                            <span class="font-weight-bolder font-size-h5">@(totalLines)</span>
                        </div>
                    </div>
                    <div class="d-flex align-items-center flex-lg-fill mr-5 my-1">
                        <span class="mr-4"><i class="flaticon-check-mark icon-2x text-success font-weight-bold"></i></span>
                        <div class="d-flex flex-column text-dark-75">
                            <span class="font-weight-bolder font-size-sm">Tamamlanan</span>
                            <span class="font-weight-bolder font-size-h5">@(completedLines)</span>
                        </div>
                    </div>
                    <div class="d-flex align-items-center flex-lg-fill mr-5 my-1">
                        <span class="mr-4"><i class="flaticon-interface icon-2x text-info font-weight-bold"></i></span>
                        <div class="d-flex flex-column text-dark-75 w-100">
                            <span class="font-weight-bolder font-size-sm">İlerleme</span>
                            <div class="progress" style="height: 10px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width: @progressPercent%" aria-valuenow="@progressPercent" aria-valuemin="0" aria-valuemax="100">@progressPercent.ToString("0")%</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!--begin::Tabs Card-->
        <div class="card card-custom gutter-b">
            <div class="card-header border-0 pt-4 pb-0">
                <ul class="nav nav-tabs nav-tabs-line nav-tabs-bold nav-tabs-line-3x" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" data-toggle="tab" href="#tab-overview" role="tab">
                            <i class="flaticon2-graphic"></i>
                            Özet
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#tab-lines" role="tab">
                            <i class="flaticon-interface"></i>
                            Fazlar
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#tab-works" role="tab">
                            <i class="flaticon-list-1"></i>
                            İşler
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#tab-notes" role="tab">
                            <i class="flaticon2-paper"></i>
                            Notlar
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#tab-files" role="tab">
                            <i class="flaticon2-file"></i>
                            Dosyalar
                        </a>
                    </li>
                </ul>
            </div>

            <div class="card-body">
                <div class="tab-content">
                    <!-- Tab: Overview -->
                    <div class="tab-pane fade show active" id="tab-overview" role="tabpanel">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="card card-stretch gutter-b">
                                    <div class="card-header border-0">
                                        <h3 class="card-title font-weight-bolder">Proje Bilgileri</h3>
                                    </div>
                                    <div class="card-body">
                                        <table class="table table-borderless">
                                            <tr>
                                                <td style="width: 40%"><strong>Proje Kodu:</strong></td>
                                                <td>@Model.project.ProjectCode</td>
                                            </tr>
                                            <tr>
                                                <td><strong>Proje Adı:</strong></td>
                                                <td>@Model.project.ProjectName</td>
                                            </tr>
                                            <tr>
                                                <td><strong>Açıklama:</strong></td>
                                                <td>@Model.project.Description</td>
                                            </tr>
                                            <tr>
                                                <td><strong>Proje Yöneticisi:</strong></td>
                                                <td>@Model.project.ProjectManager</td>
                                            </tr>
                                            <tr>
                                                <td><strong>Firma Yetkilisi:</strong></td>
                                                <td>@Model.project.FirmPerson</td>
                                            </tr>
                                            <tr>
                                                <td><strong>Başlangıç Tarihi:</strong></td>
                                                <td>@Model.project.StartDate</td>
                                            </tr>
                                            <tr>
                                                <td><strong>Termin Tarihi:</strong></td>
                                                <td>@Model.project.DueDate</td>
                                            </tr>
                                            <tr>
                                                <td><strong>Durum:</strong></td>
                                                <td>
                                                    @{
                                                        var statusBadge = Model.project.ProjectStatus switch
                                                        {
                                                            ProjectStatusEnum.Creating => "<span class='badge badge-secondary'>Oluşturuluyor</span>",
                                                            ProjectStatusEnum.Created => "<span class='badge badge-primary'>Oluşturuldu</span>",
                                                            ProjectStatusEnum.Started => "<span class='badge badge-info'>Başladı</span>",
                                                            ProjectStatusEnum.Testing => "<span class='badge badge-warning'>Test Aşamasında</span>",
                                                            ProjectStatusEnum.Finished => "<span class='badge badge-success'>Tamamlandı</span>",
                                                            ProjectStatusEnum.Canceled => "<span class='badge badge-danger'>İptal Edildi</span>",
                                                            _ => "<span class='badge badge-secondary'>Belirsiz</span>"
                                                        };
                                                    }
                                                    @Html.Raw(statusBadge)
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card card-stretch gutter-b">
                                    <div class="card-header border-0">
                                        <h3 class="card-title font-weight-bolder">Firma Bilgileri</h3>
                                    </div>
                                    <div class="card-body">
                                        <table class="table table-borderless">
                                            <tr>
                                                <td style="width: 40%"><strong>Firma Kodu:</strong></td>
                                                <td>@Model.firm.Code</td>
                                            </tr>
                                            <tr>
                                                <td><strong>Firma Adı:</strong></td>
                                                <td>@Model.firm.Title</td>
                                            </tr>
                                            <tr>
                                                <td><strong>Telefon:</strong></td>
                                                <td>@Model.firm.Phone</td>
                                            </tr>
                                            <tr>
                                                <td><strong>E-Posta:</strong></td>
                                                <td><a href="mailto:@Model.firm.EmailAddress1">@Model.firm.EmailAddress1</a></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Tab: Fazlar -->
                    <div class="tab-pane fade" id="tab-lines" role="tabpanel">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h3 class="font-weight-bolder">Proje Fazları</h3>
                            <div>
                                <select id="bulkStatusSelect" class="form-control d-inline-block mr-2" style="width: 200px;">
                                    <option value="">Toplu İşlem Seç...</option>
                                    <option value="1">Başlamadı</option>
                                    <option value="2">Devam Ediyor</option>
                                    <option value="5">Tamamlandı</option>
                                    <option value="6">İptal Edildi</option>
                                </select>
                                <button type="button" id="bulkApplyStatus" class="btn btn-sm btn-primary">Uygula</button>
                                <a href="#" id="open-add-project-line-modal" class="btn btn-sm btn-success font-weight-bolder ml-2">
                                    <i class="flaticon2-plus"></i> Faz Ekle
                                </a>
                            </div>
                        </div>

                        <table class="table table-bordered table-hover" id="ProjectLineTable">
                            <thead>
                                <tr>
                                    <th width="40"><input type="checkbox" id="selectAllLines" /></th>
                                    <th>Faz Adı</th>
                                    <th>Durum</th>
                                    <th>Teslim Tarihi</th>
                                    <th>Başlangıç Tarihi</th>
                                    <th>Faz Yöneticisi</th>
                                    <th>Firma Yetkilisi</th>
                                    <th>Öncelik</th>
                                    <th>Sıra</th>
                                    <th>İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.project.ProjectLines != null && Model.project.ProjectLines.Any())
                                {
                                    @foreach (var item in Model.project.ProjectLines)
                                    {
                                        var lineStatusBadge = item.StateStatus switch
                                        {
                                            ProjectLineStatusEnum.NotStarted => "<span class='badge badge-secondary'>Başlamadı</span>",
                                            ProjectLineStatusEnum.InProgress => "<span class='badge badge-info'>Devam Ediyor</span>",
                                            ProjectLineStatusEnum.Completed => "<span class='badge badge-success'>Tamamlandı</span>",
                                            ProjectLineStatusEnum.Cancellled => "<span class='badge badge-danger'>İptal Edildi</span>",
                                            _ => "<span class='badge badge-secondary'>Belirsiz</span>"
                                        };
                                        <tr data-id="@item.Id" data-title="@item.Title" data-official-id="@item.LineOfficialId" data-firm-official-id="@item.LineFirmOfficialId" data-priority="@((int)item.Priority)" data-roworder="@item.RowOrder" data-description="@item.Description" data-duedate="@item.DueDate">
                                            <td><input type="checkbox" class="line-checkbox" data-id="@item.Id" /></td>
                                            <td>@item.Title</td>
                                            <td>@Html.Raw(lineStatusBadge)</td>
                                            <td>@item.DueDate</td>
                                            <td>@item.StartDate</td>
                                            <td>@item.LineOfficial</td>
                                            <td>@item.LineFirmOfficial</td>
                                            <td>@item.Priority</td>
                                            <td>@item.RowOrder</td>
                                            <td>
                                                <button type="button" class="btn btn-icon btn-success btn-sm btn-start-phase" data-toggle="tooltip" title="Faza Başla" data-id="@item.Id"><i class="flaticon2-play"></i></button>
                                                <button type="button" class="btn btn-icon btn-warning btn-sm btn-complete-phase" data-toggle="tooltip" title="Tamamla" data-id="@item.Id"><i class="flaticon2-check-mark"></i></button>
                                                <button type="button" class="btn btn-icon btn-primary btn-sm btn-edit-phase" data-toggle="tooltip" title="Düzenle"><i class="flaticon2-pen"></i></button>
                                                <button type="button" class="btn btn-icon btn-info btn-sm btn-notes-phase" data-toggle="tooltip" title="Notlar" data-id="@item.Id" data-title="@item.Title"><i class="flaticon2-paper"></i></button>
                                                <button type="button" class="btn btn-icon btn-purple btn-sm btn-works-phase" data-toggle="tooltip" title="İşler" data-id="@item.Id" data-title="@item.Title"><i class="flaticon-list-1"></i></button>
                                                <button type="button" class="btn btn-icon btn-danger btn-sm btn-delete-phase" data-toggle="tooltip" title="Sil" data-id="@item.Id"><i class="flaticon2-trash"></i></button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="10" class="text-center">Kayıtlı faz bulunmamaktadır.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Tab: İşler -->
                    <div class="tab-pane fade" id="tab-works" role="tabpanel">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h3 class="font-weight-bolder">Tüm İşler</h3>
                        </div>
                        <div class="alert alert-info">
                            <i class="flaticon-info mr-2"></i>
                            Bu bölüm tüm fazların işlerini bir arada gösterir. İş detaylarını görmek için ilgili faza tıklayın.
                        </div>
                        <div id="all-works-container">
                            <div class="text-center py-5">
                                <span class="text-muted">İş listesi yükleniyor...</span>
                            </div>
                        </div>
                    </div>

                    <!-- Tab: Notlar -->
                    <div class="tab-pane fade" id="tab-notes" role="tabpanel">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h3 class="font-weight-bolder">Tüm Notlar</h3>
                        </div>
                        <div id="all-notes-container">
                            <div class="text-center py-5">
                                <span class="text-muted">Not listesi yükleniyor...</span>
                            </div>
                        </div>
                    </div>

                    <!-- Tab: Dosyalar -->
                    <div class="tab-pane fade" id="tab-files" role="tabpanel">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h3 class="font-weight-bolder">Proje Dosyaları</h3>
                            <a href="#" id="open-add-project-file-modal-tab" class="btn btn-sm btn-success font-weight-bolder">
                                <i class="flaticon2-plus"></i> Dosya Yükle
                            </a>
                        </div>
                        @if (Model.project.ProjectFiles != null && Model.project.ProjectFiles.Any())
                        {
                            <table class="table table-bordered table-hover">
                                <thead>
                                    <tr>
                                        <th>Dosya Adı</th>
                                        <th>Açıklama</th>
                                        <th>İşlemler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var file in Model.project.ProjectFiles)
                                    {
                                        <tr data-id="@file.Id">
                                            <td><i class="flaticon-file text-primary mr-2"></i>@file.Name</td>
                                            <td>@file.Description</td>
                                            <td>
                                                <a href="/Project/DownloadProjectFile?fileId=@file.Id" class="btn btn-icon btn-success btn-sm" data-toggle="tooltip" title="İndir"><i class="flaticon-download"></i></a>
                                                <button type="button" class="btn btn-icon btn-danger btn-sm btn-delete-file" data-toggle="tooltip" title="Sil" data-id="@file.Id"><i class="flaticon2-trash"></i></button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <span class="text-muted">Henüz dosya yüklenmemiş.</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Support Tickets Section (at the bottom) -->
        <div class="row">
            @await Html.PartialAsync("_SupportListPartial", (Model.supports, Model.crmUsers, Model.userDepartments))
            @await Html.PartialAsync("_SupportModalsPartial")
        </div>

    </div>
</div>

<!-- All Modals -->
<!-- Faz Ekle Modal -->
<div class="modal fade" id="add-project-line-modal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Faz Ekle - @Model.project.ProjectName</h5>
                <button type="button" class="close" data-dismiss="modal"><i class="ki ki-close"></i></button>
            </div>
            <div class="modal-body">
                <form class="form" id="addProjectLineForm">
                    <input type="hidden" id="add_ProjectId" name="add_ProjectId" value="@Model.project.Id" />
                    <div class="form-group row">
                        <label class="col-form-label text-right col-lg-2">Faz Adı</label>
                        <div class="col-lg-4"><input type="text" id="add_LineTitle" class="form-control" required /></div>
                        <label class="col-form-label text-right col-lg-2">Sıra No</label>
                        <div class="col-lg-4"><input type="number" id="add_LineRowNumber" class="form-control" /></div>
                    </div>
                    <div class="form-group row">
                        <label class="col-form-label text-right col-lg-2">Faz Yöneticisi</label>
                        <div class="col-lg-4"><user-select id="add_LineOfficialId"></user-select></div>
                        <label class="col-form-label text-right col-lg-2">Firma Yetkilisi</label>
                        <div class="col-lg-4"><firm-contact-select id="add_LineFirmOfficial" firm-id="@Model.firm.Id"></firm-contact-select></div>
                    </div>
                    <div class="form-group row">
                        <label class="col-form-label text-right col-lg-2">Öncelik</label>
                        <div class="col-lg-4"><priority-enum-select selected-value="@PriorityEnum.Normal" id="add_LinePriority"></priority-enum-select></div>
                        <label class="col-form-label text-right col-lg-2">Teslim Tarihi</label>
                        <div class="col-lg-4">
                            <div class="input-group date" id="add_DueDate" data-target-input="nearest">
                                <input class="form-control" id="add_DueDate_tb" placeholder="Teslim Tarihi" />
                                <div class="input-group-append" data-target="#add_DueDate" data-toggle="datetimepicker">
                                    <span class="input-group-text"><i class="ki ki-calendar"></i></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Faz Açıklaması</label>
                        <textarea id="add_LineDescription" class="form-control" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light-primary" data-dismiss="modal">İptal</button>
                <button type="button" id="add_project_line_save_bt" class="btn btn-success">Faz Ekle</button>
            </div>
        </div>
    </div>
</div>

<!-- Faz Düzenle Modal -->
<div class="modal fade" id="edit-project-line-modal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Faz Düzenle</h5>
                <button type="button" class="close" data-dismiss="modal"><i class="ki ki-close"></i></button>
            </div>
            <div class="modal-body">
                <form class="form" id="editProjectLineForm">
                    <input type="hidden" id="edit_Id" />
                    <div class="form-group row">
                        <label class="col-form-label text-right col-lg-2">Faz Adı</label>
                        <div class="col-lg-4"><input type="text" id="edit_Title" class="form-control" /></div>
                        <label class="col-form-label text-right col-lg-2">Sıra No</label>
                        <div class="col-lg-4"><input type="number" id="edit_RowOrder" class="form-control" /></div>
                    </div>
                    <div class="form-group row">
                        <label class="col-form-label text-right col-lg-2">Faz Yöneticisi</label>
                        <div class="col-lg-4"><user-select id="edit_LineOfficialId"></user-select></div>
                        <label class="col-form-label text-right col-lg-2">Firma Yetkilisi</label>
                        <div class="col-lg-4"><firm-contact-select id="edit_LineFirmOfficialId" firm-id="@Model.firm.Id"></firm-contact-select></div>
                    </div>
                    <div class="form-group row">
                        <label class="col-form-label text-right col-lg-2">Öncelik</label>
                        <div class="col-lg-4"><priority-enum-select id="edit_Priority"></priority-enum-select></div>
                        <label class="col-form-label text-right col-lg-2">Teslim Tarihi</label>
                        <div class="col-lg-4">
                            <div class="input-group date" id="edit_DueDate">
                                <input class="form-control" id="edit_DueDate_tb" placeholder="Teslim Tarihi" />
                                <div class="input-group-append" data-target="#edit_DueDate" data-toggle="datetimepicker">
                                    <span class="input-group-text"><i class="ki ki-calendar"></i></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Faz Açıklaması</label>
                        <textarea id="edit_Description" class="form-control" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light-primary" data-dismiss="modal">İptal</button>
                <button type="button" id="edit_project_line_save_bt" class="btn btn-success">Güncelle</button>
            </div>
        </div>
    </div>
</div>

<!-- File Upload Modal -->
<div class="modal fade" id="add-project-file-modal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Dosya Yükle</h5>
                <button type="button" class="close" data-dismiss="modal"><i class="ki ki-close"></i></button>
            </div>
            <div class="modal-body">
                <form class="form" id="addProjectFileForm" enctype="multipart/form-data">
                    <input type="hidden" id="file_ProjectId" name="ProjectId" value="@Model.project.Id" />
                    <div class="form-group">
                        <label>Dosya Adı</label>
                        <input type="text" id="file_Name" name="Name" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label>Açıklama</label>
                        <textarea id="file_Description" name="Description" class="form-control" rows="2"></textarea>
                    </div>
