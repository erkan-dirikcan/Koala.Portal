@using Microsoft.AspNetCore.Mvc.TagHelpers
@model Koala.Portal.Core.ViewModels.PortalViewModels.CreateFixtureViewModel
@{
    ViewData["Title"] = "Demirbaş Ekle";
    ViewData["ActivePage"] = "Fixtures";
    ViewData["MenuToggle"] = "Settings";
}

<div class="d-flex flex-column-fluid">

    <div class="container-fluid">

        <div class="row">

            <div class="col-lg-12">
                <form name="CreateUserForm" id="CreateFixtureForm" asp-action="CreateFixture" asp-controller="Fixture" method="post">
                    <div class="card card-custom card-stretch gutter-b">
                        <div class="card-header border-0 py-5">
                            <h3 class="card-title align-items-start flex-column">
                                <span class="card-label font-weight-bolder text-dark">Demirbaş Yönetimi</span>
                                <span class="text-muted mt-3 font-weight-bold font-size-sm">Yeni Demirbaş Ekle</span>
                            </h3>
                        </div>
                        <div class="card-body pt-0 pb-3">
                            <div class="tab-content">

                                @*<div class="text-center">
                                <h1 class="display-4">Hoşgeşdiniz</h1>
                                <p>Koala Hakkında Daha Fazla Bilgiye Ulaşmak için  <a href="mailto:info@sistem-bilgisayar.com" target="_blank">Mail Atınız</a>.</p>
                                </div>*@


                                <div asp-validation-summary="ModelOnly"></div>

                                <div class="form-group row">
                                    <label asp-for="Name" class="col-md-1 col-form-label"></label>
                                    <div class="col-md-3">
                                        <input class="form-control form-control-sm" asp-for="Name" type="text" />
                                        <span asp-validation-for="Name" class="text-danger"></span>
                                    </div>
                                    <label asp-for="Description" class="col-md-1 col-form-label"></label>
                                    <div class="col-md-5">
                                        <input class="form-control form-control-sm" asp-for="Description" type="text" />
                                        <span asp-validation-for="Description" class="text-danger"></span>
                                    </div>
                                    <label class="col-1 col-form-label" asp-for="IsVehicle"></label>
                                    <div class="col-1">
                                        <span class="switch switch-outline switch-sm switch-icon switch-success">
                                            <label>
                                                <input type="checkbox" asp-for="@Model.IsVehicle" />
                                                <span></span>
                                            </label>
                                        </span>
                                    </div>
                                </div>

                             
                            </div>
                        </div>
                        <div class="card-footer">
                            <button type="submit" class="btn btn-primary mr-2">Demirbaş Ekle</button>
                            <a href="~/Fixture" class="btn btn-secondary">Vazgeç</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>




    </div>

</div>

