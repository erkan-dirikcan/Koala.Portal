@using System.Text.RegularExpressions

@model (List<Koala.Portal.Core.ViewModels.PortalViewModels.HelpDeskCategoryInfoViewModels> categories, List<Koala.Portal.Core.ViewModels.PortalViewModels.HelpDeskProblemInfoViewModels> views,List<Koala.Portal.Core.ViewModels.PortalViewModels.HelpDeskProblemInfoViewModels> latest)
@{
    var errorMessage = TempData["ErrorMessage"] == null ? "" : TempData["ErrorMessage"].ToString();
    var infoMessage = TempData["InfoMessage"] == null ? "" : TempData["InfoMessage"].ToString();
    ViewData["Title"] = "Yardım Masası Merkezi";
}

<div class="d-flex flex-column-fluid">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-12">
                <div class="card card-custom">
                    <div class="card-header flex-wrap border-0 pt-6 pb-0">
                        <div class="card-title">
                            <h3 class="card-label">
                                Yardım Masası
                                <span class="d-block text-muted pt-2 font-size-sm">Yardım Masası Merkezi </span>
                            </h3>
                        </div>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(infoMessage))
                        {
                            <div class="alert alert-success" role="alert">
                                @infoMessage
                                <div class="alert-close">
                                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true"><i class="ki ki-close"></i></span>
                                    </button>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger" role="alert">
                                @errorMessage
                                <div class="alert-close">
                                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true"><i class="ki ki-close"></i></span>
                                    </button>
                                </div>
                            </div>
                        }
                        <div class="faq-search">
                            <form id="searchform" asp-action="SearchResult" asp-controller="HelpDesk" class="form-horizontal" method="get" role="form">
                                <div class="form-group">
                                    <div class="col-lg-12">
                                        <input type="text" class="searchfield text form-control" id="tag" name="tag" placeholder="Aranacak ...">
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="col-xl-12">
                            <div class="card card-custom card-stretch gutter-b">
                                <div class="card-header border-0">
                                    <h3 class="card-title font-weight-bolder text-dark">Kategoriler</h3>
                                </div>
                                <div class="card-body pt-0 row">
                                    <div class="col-md-4">
                                        @for (int i = 0; i < Model.categories.Count; i++)
                                        {
                                            if (i % 3 == 0)
                                            {
                                                var c = Model.categories[i];

                                                <div class="d-flex align-items-center pt-10">
                                                    <div class="symbol symbol-45 symbol-light mr-5">
                                                        <span class="symbol-label">
                                                            <i class="flaticon-folder-1 text-success"></i>
                                                        </span>
                                                    </div>
                                                    <div class="d-flex flex-column flex-grow-1">
                                                        <a href="/HelpDesk/HelpDeskProblems?Category=@c.Id" class="text-primary">@c.Name</a>
                                                        <span class="text-muted font-weight-bold">@c.Description</span>
                                                    </div>
                                                    @* <p class="text-dark m-0 pt-5 font-weight-normal text-danger">@c. İçerik</p> *@
                                                </div>
                                                <!--begin::Desc-->
                                                <!--end::Desc-->
                                            }

                                        }
                                    </div>
                                    <div class="col-md-4">
                                        @for (int i = 0; i < Model.categories.Count; i++)
                                        {
                                            if (i % 3 == 1)
                                            {
                                                var c = Model.categories[i];

                                                <div class="d-flex align-items-center  pt-10">
                                                    <div class="symbol symbol-45 symbol-light mr-5">
                                                        <span class="symbol-label">
                                                            <i class="flaticon-folder-1 text-success"></i>
                                                        </span>
                                                    </div>
                                                    <div class="d-flex flex-column flex-grow-1">
                                                        <a href="/HelpDesk/HelpDeskProblems?Category=@c.Id" class="text-primary">@c.Name</a>
                                                        <span class="text-muted font-weight-bold">@c.Description</span>
                                                    </div>
                                                    @* <p class="text-dark m-0 pt-5 font-weight-normal text-danger">@c. İçerik</p> *@
                                                </div>
                                                <!--begin::Desc-->
                                                <!--end::Desc-->
                                            }

                                        }
                                    </div>
                                    <div class="col-md-4">
                                        @for (int i = 0; i < Model.categories.Count; i++)
                                        {
                                            if (i % 3 == 2)
                                            {
                                                var c = Model.categories[i];
                                                <div class="d-flex align-items-center pt-10">
                                                    <div class="symbol symbol-45 symbol-light mr-5">
                                                        <span class="symbol-label">
                                                            <i class="flaticon-folder-1 text-success"></i>
                                                        </span>
                                                    </div>
                                                    <div class="d-flex flex-column flex-grow-1">
                                                        <a href="/HelpDesk/HelpDeskProblems?Category=@c.Id" class="text-primary">@c.Name</a>
                                                        <span class="text-muted font-weight-bold">@c.Description</span>
                                                    </div>
                                                    @* <p class="text-dark m-0 pt-5 font-weight-normal text-danger">@c. İçerik</p> *@
                                                </div>
                                                <!--begin::Desc-->
                                                <!--end::Desc-->
                                            }

                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-12">
                            <div class="card card-custom card-stretch gutter-b">
                                <div class="card-header border-0">
                                    <h3 class="card-title font-weight-bolder text-dark">Sık Okunanlar</h3>
                                </div>
                                <div class="card-body pt-0">
                                    <div class="d-flex align-items-center flex-grow-1">

                                        <div class="d-flex flex-wrap align-items-center justify-content-between w-100">
                                           @*  @if (Model.views.Count > 0)
                                            {

                                            } *@
                                            @for (int i = 0; i < 5; i++)
                                            {
                                                var mr = Model.views[i];
                                                <div class="d-flex flex-column align-items-cente py-2 w-75">
                                                    <a href="/HelpDesk/Problem?problemId=@Model.views[i].Id" class="title"><i class="flaticon2-file text-info"></i>@Model.views[i].Title </a>
                                                    <p class="txt">
                                                        @{
                                                            var content = "";
                                                            string myContent = Regex.Replace(Model.views[i].Content, @"<(.|\n)*?>", string.Empty);
                                                            content = myContent.Length > 200 ? myContent.Substring(0, 200) : myContent;
                                                        }
                                                        @Html.Raw(content)
                                                    </p>
                                                    <small><span class="info"><strong>@Model.views[i].Views</strong> Görüntüleme</span></small>
                                                </div>
                                                <!--begin::Label-->
                                                //TODO: Kategori Adı ve ID'si ile yönlendirme yapılacak.
                                                @* <span class="label label-lg label-light-success label-inline font-weight-bold py-4">@Model.views[i].CategoryName </span> *@
                                                <!--end::Label-->
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-12">
                            <div class="card card-custom card-stretch gutter-b">
                                <div class="card-header border-0">
                                    <h3 class="card-title font-weight-bolder text-dark">Son Eklenenler</h3>
                                </div>
                                <div class="card-body pt-0">
                                    <div class="d-flex align-items-center flex-grow-1">
                                        <div class="d-flex flex-wrap align-items-center justify-content-between w-100">
                                            @for (var i = 0; i < 5; i++)
                                            {
                                                var mr = Model.latest[i];
                                                <div class="d-flex flex-column align-items-cente py-2 w-75">
                                                    <a href="/HelpDesk/Problem?problemId=@Model.latest[i].Id" class="title"><i class="flaticon2-file text-info"></i>@Model.latest[i].Title </a>
                                                    <p class="txt">
                                                        @{
                                                            var content = "";
                                                            if (Model.latest[i].Content != null)
                                                            {
                                                                string myContent = Regex.Replace(Model.latest[i].Content, @"<(.|\n)*?>", string.Empty);
                                                                content = myContent.Length > 80 ?
                                                                myContent.Substring(0, 80) :
                                                                myContent;
                                                            }
                                                        }
                                                        @Html.Raw(content)
                                                    </p>
                                                    <small><span class="info"><strong>@Model.latest[i].Views</strong> Görüntüleme</span></small>


                                                </div>
                                                <!--begin::Label-->
                                                <span class="label label-lg label-light-success label-inline font-weight-bold py-4">
                                                    @{
                                                        //TODO: Kategori Adı ve ID'si ile yönlendirme yapılacak.
                                                    }
                                                    @* @Model.latest[i].CategoryName *@
                                                </span>
                                                <!--end::Label-->
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
</div>