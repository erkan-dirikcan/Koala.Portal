@using Microsoft.AspNetCore.Identity
@using Koala.Portal.Core.Models
@inject UserManager<AppUser> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
}

<!-- Notification Bell -->
<div class="dropdown">
    <button class="btn btn-outline-secondary position-relative" type="button" id="notificationDropdown" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="fas fa-bell"></i>
        <span id="notificationBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">
            0
        </span>
    </button>
    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="notificationDropdown" style="width: 350px; max-height: 500px; overflow-y: auto;">
        <li class="dropdown-header d-flex justify-content-between align-items-center">
            <span>Bildirimler</span>
            <button class="btn btn-sm btn-link p-0" onclick="markAllAsRead()">
                <small>Tümünü Oku</small>
            </button>
        </li>
        <li><hr class="dropdown-divider"></li>
        <li id="notificationList">
            <div class="text-center p-3">
                <div class="spinner-border spinner-border-sm" role="status">
                    <span class="visually-hidden">Yükleniyor...</span>
                </div>
            </div>
        </li>
        <li><hr class="dropdown-divider"></li>
        <li>
            <a class="dropdown-item text-center" href="/Notification/Index">
                Tüm Bildirimleri Gör
            </a>
        </li>
    </ul>
</div>

<style>
    .notification-item {
        padding: 10px 15px;
        border-bottom: 1px solid #dee2e6;
        cursor: pointer;
        transition: background-color 0.2s;
    }
    .notification-item:hover {
        background-color: #f8f9fa;
    }
    .notification-item.unread {
        background-color: #e7f3ff;
    }
    .notification-item.unread:hover {
        background-color: #d0e7ff;
    }
    .notification-title {
        font-weight: 600;
        margin-bottom: 2px;
    }
    .notification-message {
        font-size: 0.9em;
        color: #6c757d;
        margin-bottom: 5px;
    }
    .notification-time {
        font-size: 0.8em;
        color: #adb5bd;
    }
</style>

<script>
    let notificationCheckInterval;

    document.addEventListener('DOMContentLoaded', function () {
        loadNotifications();
        updateNotificationCount();

        // Check for new notifications every 30 seconds
        notificationCheckInterval = setInterval(function () {
            updateNotificationCount();
        }, 30000);

        // Load notifications when dropdown is shown
        const dropdownElement = document.getElementById('notificationDropdown');
        if (dropdownElement) {
            dropdownElement.addEventListener('shown.bs.dropdown', function () {
                loadNotifications();
            });
        }
    });

    async function loadNotifications() {
        try {
            const response = await fetch('/Project/GetNotifications?unreadOnly=false', {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            const result = await response.json();

            if (result.isSuccess && result.data) {
                renderNotifications(result.data);
            } else {
                renderEmptyNotifications();
            }
        } catch (error) {
            console.error('Bildirimler yüklenirken hata oluştu:', error);
            renderErrorNotifications();
        }
    }

    async function updateNotificationCount() {
        try {
            const response = await fetch('/Project/GetUnreadNotificationCount', {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            const result = await response.json();

            if (result.isSuccess) {
                const badge = document.getElementById('notificationBadge');
                if (result.count > 0) {
                    badge.textContent = result.count > 99 ? '99+' : result.count;
                    badge.classList.remove('d-none');
                } else {
                    badge.classList.add('d-none');
                }
            }
        } catch (error) {
            console.error('Bildirim sayısı güncellenirken hata oluştu:', error);
        }
    }

    function renderNotifications(notifications) {
        const container = document.getElementById('notificationList');

        if (!notifications || notifications.length === 0) {
            renderEmptyNotifications();
            return;
        }

        let html = '';
        notifications.forEach(function (notification) {
            const unreadClass = !notification.isRead ? 'unread' : '';
            html += `
                <div class="notification-item ${unreadClass}" onclick="handleNotificationClick('${notification.id}', '${notification.actionUrl}')">
                    <div class="notification-title">${notification.title}</div>
                    <div class="notification-message">${notification.message}</div>
                    <div class="notification-time">${notification.timeAgo}</div>
                </div>
            `;
        });

        container.innerHTML = html;
    }

    function renderEmptyNotifications() {
        const container = document.getElementById('notificationList');
        container.innerHTML = `
            <div class="text-center p-3 text-muted">
                <i class="fas fa-bell-slash mb-2" style="font-size: 2em;"></i>
                <p class="mb-0">Henüz bildirim yok</p>
            </div>
        `;
    }

    function renderErrorNotifications() {
        const container = document.getElementById('notificationList');
        container.innerHTML = `
            <div class="text-center p-3 text-danger">
                <i class="fas fa-exclamation-circle mb-2" style="font-size: 2em;"></i>
                <p class="mb-0">Bildirimler yüklenemedi</p>
            </div>
        `;
    }

    async function handleNotificationClick(notificationId, actionUrl) {
        // Mark as read
        try {
            await fetch('/Project/MarkNotificationAsRead', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'notificationId=' + encodeURIComponent(notificationId)
            });
        } catch (error) {
            console.error('Bildirim okundu işaretlenirken hata oluştu:', error);
        }

        // Navigate if action URL exists
        if (actionUrl) {
            window.location.href = actionUrl;
        }
    }

    async function markAllAsRead() {
        try {
            const response = await fetch('/Project/MarkAllNotificationsAsRead', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            const result = await response.json();

            if (result.isSuccess) {
                loadNotifications();
                updateNotificationCount();
            }
        } catch (error) {
            console.error('Tüm bildirimler okundu işaretlenirken hata oluştu:', error);
        }
    }

    // Cleanup on page unload
    window.addEventListener('beforeunload', function () {
        if (notificationCheckInterval) {
            clearInterval(notificationCheckInterval);
        }
    });
</script>
