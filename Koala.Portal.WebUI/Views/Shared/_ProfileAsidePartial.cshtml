@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using Koala.Portal.Core.Models
@inject UserManager<AppUser> _userManager
@{
    ClaimsPrincipal currentUser = User;
    var user = await _userManager.GetUserAsync(currentUser);
    var rolles = (await _userManager.GetRolesAsync(user)).ToList();
    var avatar = $"{user.Avatar}";
}


<!--begin::Aside-->
<div class="flex-row-auto offcanvas-mobile w-250px w-xxl-350px" id="kt_profile_aside">
    <!--begin::Profile Card-->
    <div class="card card-custom card-stretch">
        <!--begin::Body-->
        <div class="card-body pt-4">

            <!--begin::User-->
            <div class="d-flex align-items-center">
                <div class="symbol symbol-60 symbol-xxl-100 mr-5 align-self-start align-self-xxl-center">
                    <user-picture-thumbnail></user-picture-thumbnail>
                    @*<div class="symbol-label" style="background-image:url('/media/logos/KoalaKLogo001.png')"></div>*@
                    <i class="symbol-badge bg-success"></i>
                </div>
                <div>
                    <a href="#" class="font-weight-bolder font-size-h5 text-dark-75 text-hover-primary">@user.Name @user.Lastname</a>
                    <div class="text-muted">@user.Title</div>

                </div>
            </div>
            <!--end::User-->
            <!--begin::Contact-->
            <div class="py-9">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="font-weight-bold mr-2">Email:</span>
                    <a href="#" class="text-muted text-hover-primary">@user.Email</a>
                </div>
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="font-weight-bold mr-2">Telefon:</span>
                    <span class="text-muted">@user.PhoneNumber</span>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                    <span class="font-weight-bold mr-2">Departman:</span>
                    <span class="text-muted">Yazılım</span>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                    <span class="font-weight-bold mr-2">Roller:</span>
                    <span class="text-muted">@string.Join(", ", rolles)</span>

                </div>
            </div>
            <!--end::Contact-->
            <!--begin::Nav-->
            <div class="navi navi-bold navi-hover navi-active navi-link-rounded">
